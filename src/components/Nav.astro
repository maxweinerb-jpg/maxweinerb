---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/the-work', label: 'The Work' },
  { href: '/work-with-me', label: 'Work With Me' },
  { href: '/resume', label: 'Resume' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header>
  <nav>
    <a href="/" class="wordmark">maxweinerb</a>
    <ul>
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath === href || currentPath.startsWith(href + '/');
        return (
          <li>
            <a href={href} class={isActive ? 'active' : ''}>{label}</a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid rgba(28, 28, 26, 0.1);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 800px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    width: 100%;
  }

  .wordmark {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .wordmark:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
  }

  a {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.55;
    transition: opacity 0.15s;
  }

  a:hover {
    opacity: 1;
  }

  a.active {
    opacity: 1;
    color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 600px) {
    nav {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }

    ul {
      flex-wrap: wrap;
      gap: 0.75rem 1.25rem;
    }
  }
</style>
