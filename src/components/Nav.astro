---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/the-work', label: 'The Work' },
  { href: '/work-with-me', label: 'Work With Me' },
  { href: '/resume', label: 'Resume' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header>
  <nav>
    <a href="/" class="wordmark">
      <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
        <rect x="0" y="0" width="200" height="200" rx="16" fill="#1A3A6B"/>
        <text x="100" y="105" font-family="Ubuntu, sans-serif" font-weight="700" font-size="74" fill="#F5F3EE" text-anchor="middle" letter-spacing="-3">MBW</text>
        <rect x="20" y="120" width="160" height="1.5" fill="#F5F3EE" opacity="0.25"/>
        <text x="100" y="152" font-family="Ubuntu, sans-serif" font-weight="300" font-size="18" fill="#F5F3EE" text-anchor="middle" letter-spacing="10" opacity="0.85">CS &amp; AI</text>
      </svg>
    </a>
    <ul>
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath === href || currentPath.startsWith(href + '/');
        return (
          <li>
            <a href={href} class={isActive ? 'active' : ''}>{label}</a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid rgba(28, 28, 26, 0.1);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 800px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    width: 100%;
  }

  .wordmark {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .wordmark:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
  }

  a {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.55;
    transition: opacity 0.15s;
  }

  a:hover {
    opacity: 1;
  }

  a.active {
    opacity: 1;
    color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 600px) {
    nav {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }

    ul {
      flex-wrap: wrap;
      gap: 0.75rem 1.25rem;
    }
  }
</style>
