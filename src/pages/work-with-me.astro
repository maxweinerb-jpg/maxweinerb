---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Work With Me" description="Work with Max Weiner">
  <section>
    <h1>Work With Me</h1>
    <p class="intro">
      Placeholder intro — describe who you work best with and what engagements look like.
    </p>

    <div class="offerings">
      <div class="offering">
        <h2>Offering One</h2>
        <p>
          Placeholder description of the first offering. What it includes, who it's for, and
          what someone can expect from working with you in this way.
        </p>
      </div>

      <div class="offering">
        <h2>Offering Two</h2>
        <p>
          Placeholder description of the second offering. What it includes, who it's for, and
          what someone can expect from working with you in this way.
        </p>
      </div>

      <div class="offering">
        <h2>Offering Three</h2>
        <p>
          Placeholder description of the third offering. What it includes, who it's for, and
          what someone can expect from working with you in this way.
        </p>
      </div>
    </div>

    <div class="cta">
      <p>Interested? Let's talk.</p>
      <a href="mailto:maxweinerb@gmail.com">Get in touch →</a>
    </div>
  </section>
</Layout>

<style>
  h1 {
    font-family: var(--font-ubuntu);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .intro {
    font-size: 1.0625rem;
    max-width: 55ch;
    opacity: 0.8;
    margin-bottom: 3rem;
  }

  .offerings {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .offering {
    padding: 1.75rem 0;
    border-top: 1px solid rgba(28, 28, 26, 0.1);
  }

  .offering:last-child {
    border-bottom: 1px solid rgba(28, 28, 26, 0.1);
  }

  h2 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .offering p {
    font-size: 0.9375rem;
    max-width: 58ch;
    opacity: 0.75;
    line-height: 1.65;
  }

  .cta {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cta p {
    font-size: 1rem;
    opacity: 0.7;
  }

  .cta a {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    font-weight: 500;
  }
</style>
