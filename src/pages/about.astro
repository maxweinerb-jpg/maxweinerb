<style>
  h1 {
    font-family: var(--font-ubuntu);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 60ch;
