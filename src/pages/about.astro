---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="About Max Weiner">
  <section>
    <h1>About</h1>
    <div class="body">
      <p>
        Placeholder bio paragraph one. This is where you introduce yourself — your background,
