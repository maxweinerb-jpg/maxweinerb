<style>
  .page-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  h1 {
    font-family: var(--font-ubuntu);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .download {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.4rem 0.875rem;
    border-radius: 3px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }

  .download:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    opacity: 1;
  }

  .contact {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text);
    opacity: 0.5;
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .contact a {
    color: var(--color-accent);
    text-decoration: none;
    opacity: 1;
  }

  .summary {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text);
  }

  .section {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(28, 28, 26, 0.1);
  }

  h2 {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .entries {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.125rem;
  }

  .role {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .role-note {
    font-weight: 400;
    opacity: 0.5;
  }

  .date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text);
    opacity: 0.5;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .org {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text);
    display: block;
    margin-bottom: 0.5rem;
  }

  ul {
    margin: 0;
    padding-left: 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  li {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text);
  }

  @media (max-width: 600px) {
    .page-header {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }

    .entry-header {
      flex-direction: column;
      gap: 0.125rem;
    }
  }
</style>
