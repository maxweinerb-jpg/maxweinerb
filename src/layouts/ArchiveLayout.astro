---
import Layout from './Layout.astro';

interface Props {
  title?: string;
}

const { title = 'The Archive — Max on Marketing' } = Astro.props;
---

<Layout title={title} description="Max on Marketing — 2019 Georgetown grad school marketing blog, preserved.">

  <div class="arc-banner">
    <p>In 2019, I built this site for a Georgetown grad school marketing class. In 2026, while rebuilding from scratch, I asked Claude to audit it. Claude noted the About page still referenced a trip to Spain and that there was a lasagna recipe. Both were true. What follows is the complete archive.</p>
  </div>

  <div class="wp">
    <div class="wp-head">
      <div class="wp-wrap">
        <a href="/archive" class="wp-site-title">Max on Marketing</a>
      </div>
      <nav class="wp-nav">
        <div class="wp-wrap">
          <a href="/archive">Home</a>
          <a href="/archive-about">About</a>
        </div>
      </nav>
    </div>

    <div class="wp-body">
      <div class="wp-wrap">
        <slot />
      </div>
    </div>

    <div class="wp-foot">
      <p>Proudly powered by <a href="#">WordPress</a></p>
    </div>
  </div>

</Layout>

<style>
  :global(main) {
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .arc-banner {
    background: var(--color-bg);
    padding: 1.125rem 1.5rem;
    border-bottom: 1px solid rgba(28, 28, 26, 0.12);
  }

  .arc-banner p {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.7;
    color: var(--color-text);
    max-width: 900px;
    margin: 0 auto;
    opacity: 0.7;
  }

  .wp {
    background: #f7f7f7;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    color: #333;
  }

  .wp-wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .wp-head {
    background: #fff;
    border-bottom: 1px solid #ddd;
  }

  .wp-site-title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.875rem;
    font-weight: bold;
    color: #222;
    text-decoration: none;
    display: block;
    padding: 1.5rem 0 1rem;
    line-height: 1.2;
  }

  .wp-site-title:hover {
    color: #0073aa;
    opacity: 1;
  }

  .wp-nav {
    background: #222;
  }

  .wp-nav .wp-wrap {
    display: flex;
    align-items: center;
  }

  .wp-nav a {
    color: #eee;
    text-decoration: none;
    font-size: 0.875rem;
    padding: 0.625rem 1.125rem;
    display: inline-block;
    transition: background 0.1s;
  }

  .wp-nav a:hover {
    background: #444;
    color: #fff;
    opacity: 1;
  }

  .wp-body {
    background: #fff;
    min-height: 400px;
  }

  .wp-body .wp-wrap {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  .wp-foot {
    background: #111;
    padding: 1.25rem 1.5rem;
    text-align: center;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .wp-foot a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
  }

  .wp-foot a:hover {
    color: #fff;
    opacity: 1;
  }

  /* Shared post content typography — applied globally so slot content picks it up */
  :global(.wp-content p) {
    font-size: 1rem;
    line-height: 1.8;
    color: #444;
    margin-bottom: 1.25rem;
    max-width: 70ch;
  }

  :global(.wp-content h2) {
    font-family: Georgia, serif;
    font-size: 1.375rem;
    font-weight: bold;
    color: #222;
    margin: 2rem 0 0.75rem;
  }

  :global(.wp-content h3) {
    font-size: 1.0625rem;
    font-weight: bold;
    color: #222;
    margin: 1.75rem 0 0.5rem;
  }

  :global(.wp-content ul),
  :global(.wp-content ol) {
    font-size: 1rem;
    line-height: 1.75;
    color: #444;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    max-width: 65ch;
  }

  :global(.wp-content li) {
    margin-bottom: 0.25rem;
  }

  :global(.wp-content blockquote) {
    border-left: 4px solid #0073aa;
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 1.5rem 0;
    color: #555;
    font-style: italic;
    font-size: 1rem;
    line-height: 1.7;
    max-width: 62ch;
  }

  :global(.wp-content strong) {
    color: #222;
  }

  :global(.wp-content em) {
    font-style: italic;
  }
</style>
